{
  "id": "wk-custom-001",
  "name": "เครื่องมือสร้างใบงานอัจฉริยะ (Custom Thai Worksheet)",
  "steps": [
    {
      "id": "step-1",
      "type": "input",
      "params": {
        "type": "copy_words",
        "questionCount": 5
      }
    },
    {
      "id": "step-2",
      "type": "bank_retrieve",
      "params": {
        "inputs": {
          "subjectId": "step-1.subject",
          "grade": "step-1.grade",
          "chapterCode": "step-1.indicatorCode",
          "worksheetType": "step-1.type",
          "questionCount": "step-1.questionCount"
        }
      }
    },
    {
      "id": "step-3",
      "type": "format",
      "params": {
        "aiStepId": "step-2"
      }
    },
    {
      "id": "step-4",
      "type": "export",
      "params": {
        "formatStepId": "step-3",
        "format": "txt"
      }
    },
    {
      "id": "step-5",
      "type": "export",
      "params": {
        "formatStepId": "step-3",
        "format": "docx"
      }
    },
    {
      "id": "step-6",
      "type": "export",
      "params": {
        "formatStepId": "step-3",
        "format": "pdf"
      }
    }
  ]
}
